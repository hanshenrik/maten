---
const { user } = Astro.locals;
---

<header class="bg-primary px-4 py-4 text-white shadow-md">
  <div class="container mx-auto flex items-center justify-between">
    <a href="/" class="hover:text-accent text-2xl font-bold transition-colors"
      >Maten</a
    >

    <div class="flex items-center gap-6">
      <nav class="hidden gap-4 md:flex">
        <a href="/" class="hover:text-accent transition-colors">Home</a>
        <a href="/recipes" class="hover:text-accent transition-colors"
          >Recipes</a
        >
        <a href="/plan" class="hover:text-accent transition-colors">Plan</a>
        <a href="/shopping" class="hover:text-accent transition-colors"
          >Shopping</a
        >
      </nav>

      {
        user && (
          <form action="/api/auth/logout" method="POST" class="inline">
            <button
              type="submit"
              class="rounded-lg border border-white/20 bg-white/10 px-4 py-2 text-sm font-medium transition-all hover:bg-white/20"
            >
              Logout
            </button>
          </form>
        )
      }
    </div>
  </div>
</header>
