---
import { Icon } from "astro-icon/components";
const { user, pendingInvitesCount } = Astro.locals;
---

<nav
  class="fixed bottom-0 left-0 z-50 w-full border-t border-gray-200 bg-white px-4 pt-4 pb-6"
>
  <div class="container mx-auto flex justify-around">
    <a
      href="/"
      class="text-secondary hover:text-primary flex flex-col items-center transition-colors"
    >
      <Icon
        name="streamline-ultimate-color:ice-cream-cone"
        class="mb-1 h-6 w-6"
      />
      <span class="mt-1 text-xs">Hjem</span>
    </a>
    <a
      href="/recipes"
      class="text-secondary hover:text-primary flex flex-col items-center transition-colors"
    >
      <Icon
        name="streamline-ultimate-color:archive-books"
        class="mb-1 h-6 w-6"
      />
      <span class="mt-1 text-xs">Oppskrifter</span>
    </a>
    <a
      href="/plan"
      class="text-secondary hover:text-primary flex flex-col items-center transition-colors"
    >
      <Icon name="streamline-ultimate-color:tea-pot" class="mb-1 h-6 w-6" />
      <span class="mt-1 text-xs">Planlegg</span>
    </a>
    <a
      href="/shopping"
      class="text-secondary hover:text-primary flex flex-col items-center transition-colors"
    >
      <Icon
        name="streamline-ultimate-color:notes-checklist-flip"
        class="mb-1 h-6 w-6"
      />
      <span class="mt-1 text-xs">Handleliste</span>
    </a>
    <a
      href="/settings"
      class="text-secondary hover:text-primary relative flex flex-col items-center transition-colors"
    >
      <Icon name="hugeicons:settings-03" class="mb-1 h-6 w-6" />
      {
        pendingInvitesCount > 0 && (
          <span class="absolute top-0 right-1 h-2.5 w-2.5 rounded-full bg-red-500 shadow-sm" />
        )
      }
      <span class="mt-1 text-xs">Instillinger</span>
    </a>
  </div>
</nav>
