---
import BaseLayout from "../layouts/BaseLayout.astro";
import MainNavigation from "../components/MainNavigation.astro";

const title = "Hjem";
---

<BaseLayout title={title}>
  <div class="flex min-h-screen flex-col">
    <main class="container mx-auto max-w-6xl flex-1 px-4 py-8">
      <h1 class="text-primary mb-6 text-3xl font-bold">Maten</h1>

      <div class="grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-4">
        <div class="rounded-lg border border-gray-100 bg-white p-6 shadow-sm">
          <h2 class="text-primary mb-4 text-xl font-semibold">
            Oppskrifter
          </h2>
          <p class="text-secondary mb-4">
            Bla gjennom og administrer favorittoppskriftene dine.
          </p>
          <a href="/recipes" class="text-accent font-medium hover:underline"
            >Se oppskrifter</a
          >
        </div>

        <div class="rounded-lg border border-gray-100 bg-white p-6 shadow-sm">
          <h2 class="text-primary mb-4 text-xl font-semibold">
            Middagsplanlegging
          </h2>
          <p class="text-secondary mb-4">Planlegg ukentlige middager lekende lett.</p>
          <a href="/plan" class="text-accent font-medium hover:underline"
            >Planlegg middager</a
          >
        </div>

        <div class="rounded-lg border border-gray-100 bg-white p-6 shadow-sm">
          <h2 class="text-primary mb-4 text-xl font-semibold">Handleliste</h2>
          <p class="text-secondary mb-4">
            Generer handleliste fra middagsplanene dine.
          </p>
          <a href="/shopping" class="text-accent font-medium hover:underline"
            >Se handleliste</a
          >
        </div>
      </div>
    </main>

    <MainNavigation />
  </div>
</BaseLayout>
