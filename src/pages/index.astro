---
import BaseLayout from "../layouts/BaseLayout.astro";
import MainNavigation from "../components/MainNavigation.astro";
import { Icon } from "astro-icon/components";

const title = "Hjem";
---

<BaseLayout title={title}>
  <div class="flex min-h-screen flex-col">
    <main class="container mx-auto max-w-6xl flex-1 px-4 py-8">
      <h1 class="text-text mb-6 flex items-center gap-3 text-3xl font-bold">
        <Icon name="streamline-ultimate-color:ice-cream-cone" class="h-8 w-8" />
        Maten
      </h1>

      <div class="grid grid-cols-1 gap-8 md:grid-cols-3">
        <a
          href="/recipes"
          class="border-border bg-surface block rounded-3xl border p-8"
        >
          <div
            class="mb-4 flex h-16 w-16 items-center justify-center rounded-2xl bg-blue-50"
          >
            <Icon
              name="streamline-ultimate-color:archive-books"
              class="h-10 w-10"
            />
          </div>
          <h2 class="text-text mb-2 text-2xl font-bold">Oppskrifter</h2>
          <p class="text-text-muted mb-6 leading-relaxed">
            Bla gjennom og administrer favorittoppskriftene dine.
          </p>
        </a>

        <a
          href="/plan"
          class="border-border bg-surface block rounded-3xl border p-8"
        >
          <div
            class="mb-4 flex h-16 w-16 items-center justify-center rounded-2xl bg-orange-50"
          >
            <Icon name="streamline-ultimate-color:tea-pot" class="h-10 w-10" />
          </div>
          <h2 class="text-text mb-2 text-2xl font-bold">Middagsplanlegging</h2>
          <p class="text-text-muted mb-6 leading-relaxed">
            Planlegg ukentlige middager lekende lett.
          </p>
        </a>

        <a
          href="/shopping"
          class="border-border bg-surface block rounded-3xl border p-8"
        >
          <div
            class="mb-4 flex h-16 w-16 items-center justify-center rounded-2xl bg-green-50"
          >
            <Icon
              name="streamline-ultimate-color:paper-write"
              class="h-10 w-10"
            />
          </div>
          <h2 class="text-text mb-2 text-2xl font-bold">Handleliste</h2>
          <p class="text-text-muted mb-6 leading-relaxed">
            Generer handleliste fra middagsplanene dine.
          </p>
        </a>
      </div>
    </main>
  </div>
</BaseLayout>

<MainNavigation />
