---
import BaseLayout from "../../layouts/BaseLayout.astro";
import MainNavigation from "../../components/MainNavigation.astro";
import { PlannedMealComponent as PlannedMeal } from "../../components/PlannedMeal";
import { Icon } from "astro-icon/components";
import { formatDateRange } from "../../utils/date";
import { Button } from "../../components/ui/Button";
import { ui } from "../../utils/icons";

const { id } = Astro.params;

// Fetch plan with days and recipes
const { data: plan, error } = await Astro.locals.supabase
  .from("meal_plans")
  .select(
    `
    *,
    planned_meals (
      *,
      recipes (*)
    )
  `,
  )
  .eq("id", id)
  .single();

if (error || !plan) {
  return Astro.redirect("/404");
}

const title =
  plan.title ||
  `Meny: ${formatDateRange({ start: plan.start_date, end: plan.end_date })}`;

/** Group planned_meals by date */
function groupByDate(meals: any[]): {
  date: string;
  meals: { recipeId: string; notes?: string; recipe?: any }[];
}[] {
  const map = new Map<
    string,
    { recipeId: string; notes?: string; recipe?: any }[]
  >();
  for (const m of meals || []) {
    const entries = map.get(m.date) || [];
    entries.push({
      recipeId: m.recipe_id,
      notes: m.notes,
      recipe: m.recipes
        ? {
            title: m.recipes.title,
            image_url: m.recipes.image_url,
            cook_time: m.recipes.cook_time,
          }
        : undefined,
    });
    map.set(m.date, entries);
  }
  return Array.from(map.entries())
    .sort(([a], [b]) => a.localeCompare(b))
    .map(([date, meals]) => ({ date, meals }));
}

const grouped = groupByDate(plan.planned_meals);
const todayStr = new Date().toISOString().slice(0, 10);
---

<BaseLayout title={title}>
  <div class="flex min-h-dvh flex-col">
    <main class="container mx-auto max-w-4xl flex-1 px-4 py-12">
      <div class="mb-10 flex items-center justify-between">
        <div>
          <h1 class="text-text text-3xl font-bold">{title}</h1>
          <p class="text-text-muted">
            Her er menyen deres for {
              formatDateRange({
                start: plan.start_date,
                end: plan.end_date,
              })
            }
          </p>
        </div>
        <div class="flex gap-3">
          <Button
            as="a"
            href={`/plans/${id}/edit`}
            variant="secondary"
            className="gap-2"
          >
            <Icon name={ui.edit} class="h-5 w-5" />
            Gjør endringer
          </Button>
          <Button
            as="a"
            href={`/plans/new?copyFrom=${id}`}
            variant="secondary"
            className="gap-2"
          >
            <Icon name={ui.copy} class="h-5 w-5" />
            Lag kopi
          </Button>
        </div>
      </div>

      <div
        id="meal-scroll"
        class="-mx-4 mt-8 flex gap-4 overflow-x-auto px-4 pt-8 pb-4"
      >
        {
          grouped.map((day) => {
            const isToday = day.date === todayStr;
            return (
              <div class="w-72 shrink-0" data-today={isToday ? "" : undefined}>
                <PlannedMeal
                  date={day.date}
                  meals={day.meals}
                  isToday={isToday}
                />
              </div>
            );
          })
        }
      </div>

      <script>
        setTimeout(() => {
          const container = document.getElementById("meal-scroll");
          const today = container?.querySelector(
            "[data-today]",
          ) as HTMLElement | null;
          if (!container || !today) return;

          const centered =
            today.offsetLeft -
            container.offsetLeft -
            container.clientWidth / 2 +
            today.offsetWidth / 2;
          const target = Math.max(
            0,
            Math.min(centered, container.scrollWidth - container.clientWidth),
          );
          const start = container.scrollLeft;
          const distance = target - start;
          const duration = 900;
          let startTime: number | null = null;

          // Gentle overshoot: goes ~10% past target, settles back
          function easeOutBack(t: number) {
            const overshoot = 1.1;
            return (
              1 +
              (overshoot + 1) * Math.pow(t - 1, 3) +
              overshoot * Math.pow(t - 1, 2)
            );
          }

          function step(now: number) {
            if (!startTime) startTime = now;
            const progress = Math.min((now - startTime) / duration, 1);
            container!.scrollLeft = start + distance * easeOutBack(progress);
            if (progress < 1) requestAnimationFrame(step);
          }

          requestAnimationFrame(step);
        }, 200);
      </script>
    </main>
  </div>
</BaseLayout>
