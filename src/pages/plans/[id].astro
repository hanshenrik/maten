---
import BaseLayout from "../../layouts/BaseLayout.astro";
import MainNavigation from "../../components/MainNavigation.astro";
import { PlannedMealComponent as PlannedMeal } from "../../components/PlannedMeal";
import { Icon } from "astro-icon/components";
import { formatDateRange } from "../../utils/date";
import { Button } from "../../components/ui/Button";
import { ui } from "../../utils/icons";

const { id } = Astro.params;

// Fetch plan with days and recipes
const { data: plan, error } = await Astro.locals.supabase
  .from("meal_plans")
  .select(
    `
    *,
    planned_meals (
      *,
      recipes (*)
    )
  `,
  )
  .eq("id", id)
  .single();

if (error || !plan) {
  return Astro.redirect("/404");
}

const title =
  plan.title ||
  `Meny: ${formatDateRange({ start: plan.start_date, end: plan.end_date })}`;

/** Group planned_meals by date */
function groupByDate(meals: any[]): {
  date: string;
  meals: { recipeId: string; notes?: string; recipe?: any }[];
}[] {
  const map = new Map<
    string,
    { recipeId: string; notes?: string; recipe?: any }[]
  >();
  for (const m of meals || []) {
    const entries = map.get(m.date) || [];
    entries.push({
      recipeId: m.recipe_id,
      notes: m.notes,
      recipe: m.recipes
        ? {
            title: m.recipes.title,
            image_url: m.recipes.image_url,
            cook_time: m.recipes.cook_time,
          }
        : undefined,
    });
    map.set(m.date, entries);
  }
  return Array.from(map.entries())
    .sort(([a], [b]) => a.localeCompare(b))
    .map(([date, meals]) => ({ date, meals }));
}

const grouped = groupByDate(plan.planned_meals);
---

<BaseLayout title={title}>
  <div class="flex min-h-dvh flex-col">
    <main class="container mx-auto max-w-4xl flex-1 px-4 py-12">
      <div class="mb-10 flex items-center justify-between">
        <div>
          <h1 class="text-text text-3xl font-bold">{title}</h1>
          <p class="text-text-muted">
            Her er menyen deres for {
              formatDateRange({
                start: plan.start_date,
                end: plan.end_date,
              })
            }
          </p>
        </div>
        <div class="flex gap-3">
          <Button
            as="a"
            href={`/plans/${id}/edit`}
            variant="secondary"
            className="gap-2"
          >
            <Icon name={ui.edit} class="h-5 w-5" />
            Gjør endringer
          </Button>
          <Button
            as="a"
            href={`/plans/new?copyFrom=${id}`}
            variant="secondary"
            className="gap-2"
          >
            <Icon name={ui.copy} class="h-5 w-5" />
            Lag kopi
          </Button>
        </div>
      </div>

      <div class="mt-8 space-y-6">
        {
          grouped.map((day) => (
            <PlannedMeal date={day.date} meals={day.meals} />
          ))
        }
      </div>
    </main>

    <MainNavigation />
  </div>
</BaseLayout>
