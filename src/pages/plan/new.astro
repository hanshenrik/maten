---
import BaseLayout from "../../layouts/BaseLayout.astro";
import MainNavigation from "../../components/MainNavigation.astro";
import { MealPlanningWizard } from "../../components/MealPlanningWizard";

const title = "Ny meny";
---

<BaseLayout title={title}>
  <div class="bg-bg flex min-h-screen flex-col">
    <main class="container mx-auto max-w-4xl flex-1 px-4 py-12">
      <div class="mb-10 text-center">
        <h1 class="text-text mb-2 text-3xl font-bold">Ny meny</h1>
        <p class="text-text-muted">Velg datoer og legg til oppskrifter</p>
      </div>

      <MealPlanningWizard
        client:load
        userId={Astro.locals.user.id}
        householdId={Astro.locals.householdId}
      />
    </main>

    <MainNavigation />
  </div>
</BaseLayout>
