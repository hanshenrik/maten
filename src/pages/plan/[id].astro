---
import BaseLayout from "../../layouts/BaseLayout.astro";
import MainNavigation from "../../components/MainNavigation.astro";
import { PlannedMealComponent as PlannedMeal } from "../../components/PlannedMeal";
import { Icon } from "astro-icon/components";
import { formatDateRange } from "../../utils/date";

const { id } = Astro.params;

// Fetch plan with days and recipes
const { data: plan, error } = await Astro.locals.supabase
  .from("meal_plans")
  .select(
    `
    *,
    planned_meals (
      *,
      recipes (*)
    )
  `,
  )
  .eq("id", id)
  .single();

if (error || !plan) {
  return Astro.redirect("/404");
}

const title =
  plan.title ||
  `Plan: ${formatDateRange({ start: plan.start_date, end: plan.end_date })}`;
---

<BaseLayout title={title}>
  <div class="flex min-h-screen flex-col bg-gray-50">
    <main class="container mx-auto max-w-4xl flex-1 px-4 py-12">
      <div class="mb-10 flex items-center justify-between">
        <div>
          <h1 class="text-3xl font-bold text-gray-900">{title}</h1>
          <p class="text-gray-500">
            Middagsplan for {
              formatDateRange({
                start: plan.start_date,
                end: plan.end_date,
              })
            }
          </p>
        </div>
        <div class="flex gap-3">
          <a
            href={`/plan/${id}/edit`}
            class="flex items-center gap-2 rounded-xl border border-gray-200 bg-white px-6 py-2 font-semibold text-gray-600 shadow-sm transition-colors hover:bg-gray-50"
          >
            <Icon name="hugeicons:pencil-edit-02" class="h-5 w-5" />
            Rediger
          </a>
          <a
            href={`/plan/new?copyFrom=${id}`}
            class="flex items-center gap-2 rounded-xl border border-gray-200 bg-white px-6 py-2 font-semibold text-gray-600 shadow-sm transition-colors hover:bg-gray-50"
          >
            <Icon name="hugeicons:copy-01" class="h-5 w-5" />
            Kopier
          </a>
        </div>
      </div>

      <div class="mt-8 space-y-6">
        {
          plan.planned_meals?.map((day: any) => (
            <PlannedMeal
              day={{
                day_of_week: day.date,
                recipeId: day.recipe_id,
                notes: day.notes,
              }}
              recipes={{
                [day.recipe_id]: {
                  title: day.recipes?.title,
                  image_url: day.recipes?.image_url,
                },
              }}
            />
          ))
        }
      </div>
    </main>

    <MainNavigation />
  </div>
</BaseLayout>
