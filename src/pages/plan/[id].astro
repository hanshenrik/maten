---
import BaseLayout from "../../layouts/BaseLayout.astro";
import MainNavigation from "../../components/MainNavigation.astro";
import { PlannedMealComponent as PlannedMeal } from "../../components/PlannedMeal";
import { Icon } from "astro-icon/components";
import { formatDateRange } from "../../utils/date";
import { Button } from "../../components/ui/Button";

const { id } = Astro.params;

// Fetch plan with days and recipes
const { data: plan, error } = await Astro.locals.supabase
  .from("meal_plans")
  .select(
    `
    *,
    planned_meals (
      *,
      recipes (*)
    )
  `,
  )
  .eq("id", id)
  .single();

if (error || !plan) {
  return Astro.redirect("/404");
}

const title =
  plan.title ||
  `Meny: ${formatDateRange({ start: plan.start_date, end: plan.end_date })}`;
---

<BaseLayout title={title}>
  <div class="flex min-h-dvh flex-col">
    <main class="container mx-auto max-w-4xl flex-1 px-4 py-12">
      <div class="mb-10 flex items-center justify-between">
        <div>
          <h1 class="text-text text-3xl font-bold">{title}</h1>
          <p class="text-text-muted">
            Her er menyen deres for {
              formatDateRange({
                start: plan.start_date,
                end: plan.end_date,
              })
            }
          </p>
        </div>
        <div class="flex gap-3">
          <Button
            as="a"
            href={`/plan/${id}/edit`}
            variant="secondary"
            className="gap-2"
          >
            <Icon name="hugeicons:pencil-edit-02" class="h-5 w-5" />
            Gjør endringer
          </Button>
          <Button
            as="a"
            href={`/plan/new?copyFrom=${id}`}
            variant="secondary"
            className="gap-2"
          >
            <Icon name="hugeicons:copy-01" class="h-5 w-5" />
            Lag kopi
          </Button>
        </div>
      </div>

      <div class="mt-8 space-y-6">
        {
          plan.planned_meals?.map((day: any) => (
            <PlannedMeal
              day={{
                day_of_week: day.date,
                recipeId: day.recipe_id,
                notes: day.notes,
              }}
              recipes={{
                [day.recipe_id]: {
                  title: day.recipes?.title,
                  image_url: day.recipes?.image_url,
                },
              }}
            />
          ))
        }
      </div>
    </main>

    <MainNavigation />
  </div>
</BaseLayout>
