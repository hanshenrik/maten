---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import MainNavigation from "../../../components/MainNavigation.astro";
import { DinnerPlanningWizard } from "../../../components/DinnerPlanningWizard";

const { id } = Astro.params;

// Fetch plan with days
const { data: plan, error } = await Astro.locals.supabase
  .from("dinner_plans")
  .select(
    `
    *,
    plan_days (*)
  `,
  )
  .eq("id", id)
  .single();

if (error || !plan) {
  return Astro.redirect("/404");
}

const title = "Rediger middagsplan";
---

<BaseLayout title={title}>
  <div class="flex min-h-screen flex-col bg-gray-50">
    <main class="container mx-auto max-w-4xl flex-1 px-4 py-12">
      <div class="mb-10 text-center">
        <h1 class="mb-2 text-3xl font-bold text-gray-900">Rediger middagsplan</h1>
        <p class="text-gray-500">Oppdater datoer og oppskrifter</p>
      </div>

      <DinnerPlanningWizard
        client:load
        userId={Astro.locals.user.id}
        initialData={plan}
      />
    </main>

    <MainNavigation />
  </div>
</BaseLayout>
