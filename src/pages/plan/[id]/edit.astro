---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import MainNavigation from "../../../components/MainNavigation.astro";
import { MealPlanningWizard } from "../../../components/MealPlanningWizard";

const { id } = Astro.params;

// Fetch plan with days
const { data: plan, error } = await Astro.locals.supabase
  .from("meal_plans")
  .select(
    `
    *,
    planned_meals (*)
  `,
  )
  .eq("id", id)
  .single();

if (error || !plan) {
  return Astro.redirect("/404");
}

const title = "Gjør endringer i menyen";
---

<BaseLayout title={title}>
  <div class="bg-bg flex min-h-screen flex-col">
    <main class="container mx-auto max-w-4xl flex-1 px-4 py-12">
      <div class="mb-10 text-center">
        <h1 class="text-text mb-2 text-3xl font-bold">
          Gjør endringer i menyen
        </h1>
        <p class="text-text-muted">Her kan du bytte ut datoer og oppskrifter</p>
      </div>

      <MealPlanningWizard
        client:load
        userId={Astro.locals.user.id}
        householdId={Astro.locals.householdId}
        initialData={plan}
      />
    </main>

    <MainNavigation />
  </div>
</BaseLayout>
