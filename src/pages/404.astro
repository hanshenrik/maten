---
import BaseLayout from "../layouts/BaseLayout.astro";
import MainNavigation from "../components/MainNavigation.astro";
import { Button } from "../components/ui/Button";

const title = "Her var det tomt";
---

<BaseLayout title={title}>
  <div class="flex min-h-dvh flex-col">
    <main class="container mx-auto max-w-6xl flex-1 px-4 py-8">
      <div class="py-16 text-center">
        <h1 class="text-text mb-4 text-6xl font-bold">404</h1>
        <h2 class="text-secondary mb-6 text-2xl font-semibold">
          Ops! Denne siden finnes ikke.
        </h2>
        <p class="text-secondary mx-auto mb-8 max-w-md text-lg">
          Kanskje siden har flyttet på seg, eller så har vi rotet det til.
          Uansett er det best å gå tilbake til trygg grunn.
        </p>
        <Button as="a" href="/" variant="ghost" className="gap-2">
          Gå tilbake til oversikten
        </Button>
      </div>
    </main>

    <MainNavigation />
  </div>
</BaseLayout>
