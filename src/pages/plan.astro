---
import BaseLayout from "../layouts/BaseLayout.astro";
import MainNavigation from "../components/MainNavigation.astro";
import { PlannedMealComponent as PlannedMeal } from "../components/PlannedMeal";
import { Icon } from "astro-icon/components";
import { formatISODate, formatDateRange } from "../utils/date";
import { Button } from "../components/ui/Button";
import { Details } from "../components/ui/Details";

const title = "Hva skal vi ha til middag?";

// Fetch meal plans from Supabase using the authenticated client from locals
const { data: plans = [] } = await Astro.locals.supabase
  .from("meal_plans")
  .select(
    `
    *,
    planned_meals (
      *,
      recipes (id, title, image_url, cook_time)
    )
  `,
  )
  .order("start_date", { ascending: false });

const today = formatISODate(new Date());

const activePlans = plans.filter((p) => p.end_date >= today);
const outdatedPlans = plans.filter((p) => p.end_date < today);
---

<BaseLayout title={title}>
  <div class="flex min-h-dvh flex-col">
    <main class="container mx-auto max-w-6xl flex-1 px-4 py-8">
      <div class="mb-8 flex items-center justify-between">
        <h1 class="text-text flex items-center gap-3 text-3xl font-bold">
          <Icon name="streamline-ultimate-color:tea-pot" class="h-8 w-8" />
          Dine menyer
        </h1>
        <div class="hidden md:block">
          <Button as="a" href="/plan/new" className="gap-2">
            <Icon name="hugeicons:calendar-add-01" class="h-5 w-5" />
            Lag ny meny
          </Button>
        </div>
      </div>

      <div class="mb-8 md:hidden">
        <Button as="a" href="/plan/new" className="flex w-full gap-2">
          <Icon name="hugeicons:calendar-add-01" class="h-5 w-5" />
          Lag ny meny
        </Button>
      </div>

      {
        activePlans.length > 0 ? (
          <div class="space-y-12">
            {activePlans.map((plan) => (
              <section class="space-y-4">
                <div class="flex items-center justify-between">
                  <a href={`/plan/${plan.id}`} class="group">
                    <h2 class="text-text hover:text-primary text-2xl font-bold transition-colors">
                      {plan.title || "Meny"}
                    </h2>
                    <p class="text-secondary text-sm font-medium">
                      {formatDateRange({
                        start: plan.start_date,
                        end: plan.end_date,
                      })}
                    </p>
                  </a>
                </div>
                <div class="grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3">
                  {plan.planned_meals?.map((day: any) => (
                    <PlannedMeal
                      day={{
                        day_of_week: day.date,
                        recipeId: day.recipe_id,
                        notes: day.notes,
                      }}
                      recipes={{
                        [day.recipe_id]: {
                          title: day.recipes?.title,
                          image_url: day.recipes?.image_url,
                          cook_time: day.recipes?.cook_time,
                        },
                      }}
                    />
                  ))}
                </div>
              </section>
            ))}
          </div>
        ) : outdatedPlans.length === 0 ? (
          <div class="border-border bg-surface rounded-xl border p-6">
            <p class="text-text-muted mb-4">Her var det ingen menyer å se!</p>
            <p class="text-text-muted">
              Hva med å sette opp en meny for dagene som kommer?
            </p>
          </div>
        ) : null
      }

      {
        outdatedPlans.length > 0 && (
          <Details
            className="mt-16"
            summaryClassName="text-xl font-bold"
            title={`Tidligere menyer (${outdatedPlans.length})`}
            client:load
          >
            <div class="space-y-12">
              {outdatedPlans.map((plan) => (
                <section class="space-y-4">
                  <div class="flex items-center justify-between">
                    <a href={`/plan/${plan.id}`} class="group">
                      <h2 class="text-text hover:text-primary text-xl font-bold transition-colors">
                        {plan.title || "Meny"}
                      </h2>
                      <p class="text-text-muted text-sm">
                        {formatDateRange({
                          start: plan.start_date,
                          end: plan.end_date,
                        })}
                      </p>
                    </a>
                  </div>
                  <div class="grid grid-cols-1 gap-6 opacity-60 grayscale-[0.5] md:grid-cols-2 lg:grid-cols-3">
                    {plan.planned_meals?.map((day: any) => (
                      <PlannedMeal
                        day={{
                          day_of_week: day.date,
                          recipeId: day.recipe_id,
                          notes: day.notes,
                        }}
                        recipes={{
                          [day.recipe_id]: {
                            title: day.recipes?.title,
                            image_url: day.recipes?.image_url,
                            cook_time: day.recipes?.cook_time,
                          },
                        }}
                      />
                    ))}
                  </div>
                </section>
              ))}
            </div>
          </Details>
        )
      }
    </main>

    <MainNavigation />
  </div>
</BaseLayout>
