---
import BaseLayout from "../layouts/BaseLayout.astro";
import MainNavigation from "../components/MainNavigation.astro";
import { PlannedMealComponent as PlannedMeal } from "../components/PlannedMeal";
import { Icon } from "astro-icon/components";
import { formatISODate, formatDateRange } from "../utils/date";

const title = "Plan";

// Fetch meal plans from Supabase using the authenticated client from locals
const { data: plans = [] } = await Astro.locals.supabase
  .from("meal_plans")
  .select(
    `
    *,
    planned_meals (
      *,
      recipes (*)
    )
  `,
  )
  .order("start_date", { ascending: false });

const today = formatISODate(new Date());

const activePlans = plans.filter((p) => p.end_date >= today);
const outdatedPlans = plans.filter((p) => p.end_date < today);
---

<BaseLayout title={title}>
  <div class="flex min-h-screen flex-col">
    <main class="container mx-auto max-w-6xl flex-1 px-4 py-8">
      <div class="mb-8 flex items-center justify-between">
        <h1 class="text-primary text-3xl font-bold">Ukens middagsplan</h1>
        <a
          href="/plan/new"
          class="flex items-center gap-2 rounded-lg bg-green-600 px-4 py-2 font-semibold text-white shadow-sm transition-colors hover:bg-green-700"
        >
          <Icon name="hugeicons:calendar-add-01" class="h-5 w-5" />
          Ny Plan
        </a>
      </div>

      {
        activePlans.length > 0 ? (
          <div class="space-y-12">
            {activePlans.map((plan) => (
              <section class="space-y-4">
                <div class="flex items-center justify-between">
                  <a href={`/plan/${plan.id}`} class="group">
                    <h2 class="text-2xl font-bold text-gray-900 transition-colors group-hover:text-blue-600">
                      {plan.title || "Middagsplan"}
                    </h2>
                    <p class="text-secondary text-sm font-medium">
                      {formatDateRange({
                        start: plan.start_date,
                        end: plan.end_date,
                      })}
                    </p>
                  </a>
                </div>
                <div class="grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3">
                  {plan.planned_meals?.map((day: any) => (
                    <PlannedMeal
                      day={{
                        day_of_week: day.date,
                        recipeId: day.recipe_id,
                        notes: day.notes,
                      }}
                      recipes={{
                        [day.recipe_id]: {
                          title: day.recipes?.title,
                          image_url: day.recipes?.image_url,
                        },
                      }}
                    />
                  ))}
                </div>
              </section>
            ))}
          </div>
        ) : outdatedPlans.length === 0 ? (
          <div class="rounded-lg border border-gray-100 bg-white p-6 shadow-sm">
            <p class="text-secondary mb-4">Ingen middagsplaner funnet.</p>
            <p class="text-secondary">
              Opprett en ny middagsplan for å komme i gang.
            </p>
          </div>
        ) : null
      }

      {
        outdatedPlans.length > 0 && (
          <details class="group mt-16">
            <summary class="flex cursor-pointer list-none items-center gap-2 text-xl font-bold text-gray-500 transition-colors hover:text-gray-700">
              <Icon
                name="hugeicons:arrow-right-01"
                class="h-5 w-5 transition-transform group-open:rotate-90"
              />
              Gamle planer ({outdatedPlans.length})
            </summary>
            <div class="mt-8 space-y-12">
              {outdatedPlans.map((plan) => (
                <section class="space-y-4">
                  <div class="flex items-center justify-between">
                    <a href={`/plan/${plan.id}`} class="group">
                      <h2 class="text-xl font-bold text-gray-700 transition-colors group-hover:text-blue-600">
                        {plan.title || "Middagsplan"}
                      </h2>
                      <p class="text-secondary text-sm">
                        {formatDateRange({
                          start: plan.start_date,
                          end: plan.end_date,
                        })}
                      </p>
                    </a>
                  </div>
                  <div class="grid grid-cols-1 gap-6 opacity-60 grayscale-[0.5] md:grid-cols-2 lg:grid-cols-3">
                    {plan.planned_meals?.map((day: any) => (
                      <PlannedMeal
                        day={{
                          day_of_week: day.date,
                          recipeId: day.recipe_id,
                          notes: day.notes,
                        }}
                        recipes={{
                          [day.recipe_id]: {
                            title: day.recipes?.title,
                            image_url: day.recipes?.image_url,
                          },
                        }}
                      />
                    ))}
                  </div>
                </section>
              ))}
            </div>
          </details>
        )
      }
    </main>

    <MainNavigation />
  </div>
</BaseLayout>
