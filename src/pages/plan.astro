---
import BaseLayout from "../layouts/BaseLayout.astro";
import MainNavigation from "../components/MainNavigation.astro";
import { PlannedMealComponent as PlannedMeal } from "../components/PlannedMeal";

const title = "Plan";

// Fetch meal plans from Supabase using the authenticated client from locals
const { data: plans = [] } = await Astro.locals.supabase
  .from("meal_plans")
  .select(
    `
    *,
    planned_meals (
      *,
      recipes (*)
    )
  `,
  )
  .order("start_date", { ascending: false });

// For now, we'll keep the UI similar but adapted to the new schema
// This part will be fully implemented during the Wizard task
const recipesById = {};
---

<BaseLayout title={title}>
  <div class="flex min-h-screen flex-col">
    <main class="container mx-auto max-w-6xl flex-1 px-4 py-8">
      <div class="mb-8 flex items-center justify-between">
        <h1 class="text-primary text-3xl font-bold">Ukens middagsplan</h1>
        <a
          href="/plan/new"
          class="rounded-lg bg-green-600 px-4 py-2 font-semibold text-white shadow-sm transition-colors hover:bg-green-700"
        >
          + Ny Plan
        </a>
      </div>

      {
        plans && plans.length > 0 ? (
          <div class="space-y-12">
            {plans.map((plan) => (
              <section class="space-y-4">
                <div class="flex items-center justify-between">
                  <a href={`/plan/${plan.id}`} class="group">
                    <h2 class="text-2xl font-bold text-gray-900 transition-colors group-hover:text-blue-600">
                      {plan.title ||
                        `Plan: ${plan.start_date} - ${plan.end_date}`}
                    </h2>
                  </a>
                </div>
                <div class="grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3">
                  {plan.planned_meals?.map((day: any) => (
                    <PlannedMeal
                      day={{
                        day_of_week: day.date,
                        recipeId: day.recipe_id,
                        notes: day.notes,
                      }}
                      recipes={{
                        [day.recipe_id]: { title: day.recipes?.title },
                      }}
                    />
                  ))}
                </div>
              </section>
            ))}
          </div>
        ) : (
          <div class="rounded-lg border border-gray-100 bg-white p-6 shadow-sm">
            <p class="text-secondary mb-4">Ingen middagsplaner funnet.</p>
            <p class="text-secondary">
              Opprett en ny middagsplan for å komme i gang.
            </p>
          </div>
        )
      }
    </main>

    <MainNavigation />
  </div>
</BaseLayout>
