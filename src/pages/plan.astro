---
import { supabase } from "../lib/supabase";
import BaseLayout from "../layouts/BaseLayout.astro";
import MainNavigation from "../components/MainNavigation.astro";
import { PlanDayComponent as PlanDay } from "../components/PlanDay";

const title = "Plan";

// Fetch dinner plans from Supabase
const { data: plans = [] } = await supabase
  .from("dinner_plans")
  .select(
    `
    *,
    plan_days (
      *,
      recipes (*)
    )
  `,
  )
  .order("start_date", { ascending: false });

// For now, we'll keep the UI similar but adapted to the new schema
// This part will be fully implemented during the Wizard task
const recipesById = {};
---

<BaseLayout title={title}>
  <div class="flex min-h-screen flex-col">
    <main class="container mx-auto max-w-6xl flex-1 px-4 py-8">
      <h1 class="text-primary mb-6 text-3xl font-bold">Ukens middagsplan</h1>

      {
        plans && plans.length > 0 ? (
          <div class="space-y-12">
            {plans.map((plan) => (
              <section class="space-y-4">
                <div class="flex items-center justify-between">
                  <h2 class="text-2xl font-bold text-gray-900">
                    {plan.title ||
                      `Plan: ${plan.start_date} - ${plan.end_date}`}
                  </h2>
                </div>
                <div class="grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3">
                  {plan.plan_days?.map((day) => (
                    <PlanDay
                      day={{ day_of_week: day.date, recipeId: day.recipe_id }}
                      recipes={{
                        [day.recipe_id]: { title: day.recipes?.title },
                      }}
                    />
                  ))}
                </div>
              </section>
            ))}
          </div>
        ) : (
          <div class="rounded-lg border border-gray-100 bg-white p-6 shadow-sm">
            <p class="text-secondary mb-4">Ingen middagsplaner funnet.</p>
            <p class="text-secondary">
              Opprett en ny middagsplan for å komme i gang.
            </p>
          </div>
        )
      }
    </main>

    <MainNavigation />
  </div>
</BaseLayout>
