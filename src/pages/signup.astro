---
import BaseLayout from "../layouts/BaseLayout.astro";
import { createServerClient } from "@supabase/ssr";

let errorMessage = "";
let successMessage = "";

if (Astro.request.method === "POST") {
  const formData = await Astro.request.formData();
  const email = formData.get("email")?.toString();
  const password = formData.get("password")?.toString();

  if (email && password) {
    const supabase = createServerClient(
      import.meta.env.PUBLIC_SUPABASE_URL,
      import.meta.env.PUBLIC_SUPABASE_PUBLISHABLE_KEY,
      {
        cookies: {
          getAll() {
            const cookieHeader = Astro.request.headers.get("Cookie") ?? "";
            return cookieHeader
              .split("; ")
              .filter(Boolean)
              .map((c) => {
                const [name, ...value] = c.split("=");
                return { name, value: value.join("=") };
              });
          },
          setAll(cookiesToSet) {
            cookiesToSet.forEach(({ name, value, options }) => {
              Astro.cookies.set(name, value, {
                ...options,
                maxAge: 60 * 60 * 24 * 30, // 30 days
              });
            });
          },
        },
      },
    );

    const { error } = await supabase.auth.signUp({
      email,
      password,
    });

    if (error) {
      errorMessage = error.message;
    } else {
      successMessage =
        "Herlig! Sjekk e-posten din for å vise at du er du. Etter det er det bare å logge inn.";
    }
  } else {
    errorMessage = "Husk å fylle inn både e-post og passord.";
  }
}
---

<BaseLayout title="Bli med">
  <div class="flex min-h-dvh items-center justify-center p-4">
    <div
      class="border-border bg-surface w-full max-w-md rounded-2xl border p-8"
    >
      <div class="mb-10 text-center">
        <h1 class="text-text mb-2 text-3xl font-bold">Lag deg en konto</h1>
        <p class="text-text-muted">
          Bli med i Maten og få full kontroll på middagene
        </p>
      </div>

      {
        errorMessage && (
          <div
            class="mb-6 rounded-xl border border-red-500/20 bg-red-500/10 p-4 text-sm text-red-500"
            role="alert"
          >
            {errorMessage}
          </div>
        )
      }

      {
        successMessage && (
          <div
            class="bg-primary/10 border-primary/20 text-primary mb-6 rounded-xl border p-4 text-sm"
            role="alert"
          >
            {successMessage}
          </div>
        )
      }

      {
        !successMessage && (
          <form method="POST" class="space-y-6">
            <div>
              <label
                for="email"
                class="text-text mb-1 block text-sm font-medium"
              >
                E-post
              </label>
              <input
                type="email"
                id="email"
                name="email"
                required
                class="border-border bg-surface text-text focus:ring-primary w-full rounded-xl border px-4 py-3 transition-all outline-none focus:border-transparent focus:ring-2"
                placeholder="you@example.com"
              />
            </div>

            <div>
              <label
                for="password"
                class="text-text mb-1 block text-sm font-medium"
              >
                Passord
              </label>
              <input
                type="password"
                id="password"
                name="password"
                required
                class="border-border bg-surface text-text focus:ring-primary w-full rounded-xl border px-4 py-3 transition-all outline-none focus:border-transparent focus:ring-2"
                placeholder="••••••••"
              />
            </div>

            <button
              type="submit"
              class="bg-primary hover:bg-primary-hover hover:border-primary-hover w-full transform rounded-xl border border-transparent px-4 py-3 font-semibold text-white transition-all active:scale-[0.98]"
            >
              Kjør på!
            </button>
          </form>
        )
      }

      <p class="text-text-muted mt-8 text-center text-sm">
        Har du allerede en konto? <a
          href="/login"
          class="text-primary font-medium hover:underline">Logg inn her</a
        >
      </p>
    </div>
  </div>
</BaseLayout>
