---
import BaseLayout from "../../layouts/BaseLayout.astro";
import MainNavigation from "../../components/MainNavigation.astro";
import { RecipeForm } from "../../components/RecipeForm";

const title = "New Recipe";
---

<BaseLayout title={title}>
  <div class="flex min-h-screen flex-col bg-gray-50">
    <main class="container mx-auto max-w-2xl flex-1 px-4 py-12">
      <div class="mb-10 text-center">
        <h1 class="mb-2 text-3xl font-bold text-gray-900">Ny oppskrift</h1>
        <p class="text-gray-500">Legg til en ny favoritt i samlingen din</p>
      </div>

      <RecipeForm client:load userId={Astro.locals.user.id} />
    </main>

    <MainNavigation />
  </div>
</BaseLayout>
