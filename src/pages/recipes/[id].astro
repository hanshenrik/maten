---
import BaseLayout from "../../layouts/BaseLayout.astro";
import MainNavigation from "../../components/MainNavigation.astro";
import { BasicTag } from "../../components/BasicTag";
import { Icon } from "astro-icon/components";
import { Button } from "../../components/ui/Button";

const { id } = Astro.params;

// Fetch recipe with ingredients using the authenticated client from locals
const { data: recipe, error: recipeError } = await Astro.locals.supabase
  .from("recipes")
  .select(
    `
    *,
    ingredients (*)
  `,
  )
  .eq("id", id)
  .single();

if (recipeError || !recipe) {
  return Astro.redirect("/404");
}

const title = recipe.title;
---

<BaseLayout title={title}>
  <div class="flex min-h-screen flex-col">
    <main class="container mx-auto max-w-4xl flex-1 px-4 py-12">
      <div class="mb-8 flex items-center justify-between">
        <Button variant="ghost" as="a" href="/recipes" className="gap-2">
          <Icon name="hugeicons:arrow-left-01" class="h-4 w-4" />
          Tilbake til alle oppskriftene
        </Button>
        <div class="flex gap-2">
          <Button
            as="a"
            href={`/recipes/${id}/edit`}
            variant="secondary"
            className="gap-2"
          >
            <Icon name="hugeicons:pencil-edit-02" class="h-5 w-5" />
            Gjør endringer
          </Button>
        </div>
      </div>

      <article
        class="border-border bg-surface overflow-hidden rounded-3xl border"
      >
        {
          recipe.image_url && (
            <img
              src={recipe.image_url}
              alt={recipe.title}
              class="h-64 w-full object-cover"
            />
          )
        }

        <div class="p-8">
          <div class="flex flex-col items-center justify-between md:flex-row">
            <h1
              class="text-text mb-4 flex items-center gap-3 text-2xl font-bold md:text-4xl"
            >
              <Icon
                name="streamline-ultimate-color:archive-books"
                class="h-6 w-6 md:h-10 md:w-10"
              />
              {recipe.title}
            </h1>
            {
              recipe.source_url && (
                <div class="mb-4">
                  <Button
                    variant="ghost"
                    href={recipe.source_url}
                    target="_blank"
                    rel="noopener noreferrer"
                    className="flex gap-2"
                  >
                    <Icon name="hugeicons:link-01" class="h-4 w-4" />
                    Originaloppskrift
                  </Button>
                </div>
              )
            }
          </div>
          <div class="mb-8 flex flex-wrap gap-4">
            {
              recipe.cook_time && (
                <div class="bg-surface-elevated text-text-muted border-border flex items-center gap-2 rounded-xl border px-4 py-2 text-sm font-medium">
                  <Icon
                    name="hugeicons:clock-01"
                    class="text-primary h-5 w-5"
                  />
                  <span>{recipe.cook_time} minutter</span>
                </div>
              )
            }
          </div>
          <p class="text-text-muted mb-4 text-lg">{recipe.description}</p>

          <div class="grid gap-8 md:grid-cols-3">
            <div class="md:col-span-1">
              <h2 class="text-text mb-4 text-xl font-bold">Dette trenger du</h2>
              <ul class="list-disc space-y-3">
                {
                  recipe.ingredients.map((ing: any) => (
                    <li class="text-text grid grid-cols-2 items-center gap-2">
                      <span class="flex items-center gap-1">
                        {ing.name}
                        {ing.is_basic && <BasicTag />}
                      </span>
                      {ing.amount && (
                        <span class="text-text text-sm">
                          {ing.amount} {ing.unit}
                        </span>
                      )}
                    </li>
                  ))
                }
              </ul>
            </div>

            <div class="md:col-span-2">
              <h2 class="text-text mb-4 text-xl font-bold">Slik gjør du det</h2>
              <div
                class="prose prose-emerald prose-lg text-text-muted max-w-none"
              >
                {recipe.instructions}
              </div>
            </div>
          </div>
        </div>
      </article>
    </main>

    <MainNavigation />
  </div>
</BaseLayout>
