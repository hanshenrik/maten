---
import BaseLayout from "../../layouts/BaseLayout.astro";
import MainNavigation from "../../components/MainNavigation.astro";
import { Icon } from "astro-icon/components";
import { Button } from "../../components/ui/Button";

const { id } = Astro.params;

// Fetch recipe with ingredients using the authenticated client from locals
const { data: recipe, error: recipeError } = await Astro.locals.supabase
  .from("recipes")
  .select(
    `
    *,
    ingredients (*)
  `,
  )
  .eq("id", id)
  .single();

if (recipeError || !recipe) {
  return Astro.redirect("/404");
}

const title = recipe.title;
---

<BaseLayout title={title}>
  <div class="flex min-h-screen flex-col">
    <main class="container mx-auto max-w-4xl flex-1 px-4 py-12">
      <div class="mb-8 flex items-center justify-between">
        <a
          href="/recipes"
          class="text-primary flex items-center gap-1 font-medium hover:underline"
        >
          <Icon name="hugeicons:arrow-left-04" class="h-4 w-4" />
          Tilbake til biblioteket
        </a>
        <div class="flex gap-2">
          <Button
            as="a"
            href={`/recipes/${id}/edit`}
            variant="secondary"
            className="gap-2"
          >
            <Icon name="hugeicons:pencil-edit-02" class="h-5 w-5" />
            Rediger
          </Button>
        </div>
      </div>

      <article
        class="border-border bg-surface overflow-hidden rounded-3xl border"
      >
        {
          recipe.image_url && (
            <img
              src={recipe.image_url}
              alt={recipe.title}
              class="h-64 w-full object-cover"
            />
          )
        }

        <div class="p-8">
          <h1 class="text-text mb-4 flex items-center gap-3 text-4xl font-bold">
            <Icon
              name="streamline-ultimate-color:archive-books"
              class="h-10 w-10"
            />
            {recipe.title}
          </h1>
          <p class="text-text-muted mb-4 text-lg">{recipe.description}</p>

          {
            recipe.source_url && (
              <div class="mb-8">
                <a
                  href={recipe.source_url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="bg-primary/10 text-primary hover:bg-primary/20 inline-flex items-center gap-2 rounded-full px-4 py-2 text-sm font-medium transition-colors"
                >
                  <Icon name="hugeicons:link-01" class="h-4 w-4" />
                  Se originaloppskrift
                </a>
              </div>
            )
          }

          <div class="grid gap-8 md:grid-cols-3">
            <div class="md:col-span-1">
              <h2 class="text-text mb-4 text-xl font-bold">Ingredienser</h2>
              <ul class="list-disc space-y-3">
                {
                  recipe.ingredients.map((ing: any) => (
                    <li class="grid grid-cols-2 items-center gap-2">
                      <span class="flex items-center gap-1">
                        {ing.name}
                        {ing.is_basic && (
                          <span class="bg-bg text-text-muted ml-1 rounded px-1.5 py-0.5 text-xs">
                            B
                          </span>
                        )}
                      </span>
                      <span>
                        {ing.amount && (
                          <span class="font-medium">{ing.amount} </span>
                        )}
                        {ing.unit && (
                          <span class="text-text-muted">{ing.unit} </span>
                        )}
                      </span>
                    </li>
                  ))
                }
              </ul>
            </div>

            <div class="md:col-span-2">
              <h2 class="text-text mb-4 text-xl font-bold">Fremgangsmåte</h2>
              <div
                class="prose prose-emerald prose-lg text-text-muted max-w-none"
              >
                {recipe.instructions}
              </div>
            </div>
          </div>
        </div>
      </article>
    </main>

    <MainNavigation />
  </div>
</BaseLayout>
