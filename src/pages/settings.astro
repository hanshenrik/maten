---
import { Icon } from "astro-icon/components";
import BaseLayout from "../layouts/BaseLayout.astro";
import MainNavigation from "../components/MainNavigation.astro";
import { SettingsForm } from "../components/SettingsForm";

const title = "Innstillinger";
const { user, householdId } = Astro.locals;
---

<BaseLayout title={title}>
  <div class="bg-bg flex min-h-dvh flex-col">
    <main class="container mx-auto max-w-2xl flex-1 px-4 py-12">
      <div class="mb-10">
        <h1 class="text-text flex items-center gap-3 text-3xl font-bold">
          <Icon name="streamline-ultimate-color:cog" class="h-8 w-8" />
          Innstillinger
        </h1>
        <p class="text-text-muted">
          Her styrer du alt som har med deg og huset ditt å gjøre.
        </p>
      </div>

      <SettingsForm
        client:load
        userId={user.id}
        userEmail={user.email}
        householdId={householdId}
        fullName={user.user_metadata?.full_name}
        avatarUrl={user.user_metadata?.avatar_url}
      />

      {
        user && (
          <form action="/api/auth/logout" method="POST" class="mt-10">
            <button
              type="submit"
              class="text-secondary flex cursor-pointer flex-col items-center border-none bg-transparent p-0 transition-colors hover:text-red-600"
            >
              <Icon name="hugeicons:logout-01" class="mb-1 h-6 w-6" />
              <span class="mt-1 text-xs">Logg ut</span>
            </button>
          </form>
        )
      }
    </main>

    <MainNavigation />
  </div>
</BaseLayout>
