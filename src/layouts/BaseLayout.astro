---
import Analytics from "@vercel/analytics/astro";
import SpeedInsights from "@vercel/speed-insights/astro";
import type { PropsWithChildren } from "react";
import "../styles/global.css";

interface BaseLayoutProps extends PropsWithChildren {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="no">
  <head>
    <meta charset="UTF-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1.0, viewport-fit=cover"
    />
    <meta
      name="description"
      content="Maten – din venn på kjøkkenet. Lag menyer, lagre oppskrifter og få matinnkjøpene unnagjort på et blunk."
    />
    <title>Maten - {title}</title>

    <!-- PWA manifest -->
    <link rel="manifest" href="/manifest.json" />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" href="/favicon.png" />

    <!-- Apple Touch Icon for PWA -->
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <!-- Theme color -->
    <meta name="theme-color" content="#4299E1" />

    <script is:inline>
      const applyTheme = () => {
        const theme = localStorage.getItem("theme") || "auto";
        if (theme !== "auto") {
          document.documentElement.dataset.theme = theme;
        } else {
          delete document.documentElement.dataset.theme;
        }
      };

      // Apply on initial load
      applyTheme();
    </script>

    <Analytics />
    <SpeedInsights />
  </head>
  <body class="bg-bg min-h-dvh pb-[calc(5rem+env(safe-area-inset-bottom))]">
    <slot />
    <script>
      if ("serviceWorker" in navigator) {
        window.addEventListener("load", () => {
          navigator.serviceWorker
            .register("/sw.js")
            .then((registration) => {
              console.log("SW registered:", registration);
            })
            .catch((error) => {
              console.log("SW registration failed:", error);
            });
        });
      }
    </script>
  </body>
</html>
